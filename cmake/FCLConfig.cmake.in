@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/modules")

find_dependency(Threads)
find_dependency(Boost 1.90 CONFIG COMPONENTS headers date_time iostreams url program_options)
function(_fcl_add_header_only_boost_target component)
   if(NOT TARGET Boost::${component})
      add_library(Boost::${component} INTERFACE IMPORTED)
      set_property(
         TARGET Boost::${component}
         APPEND PROPERTY INTERFACE_LINK_LIBRARIES Boost::headers
      )
   endif()
endfunction()
_fcl_add_header_only_boost_target(asio)
_fcl_add_header_only_boost_target(beast)
_fcl_add_header_only_boost_target(crc)
_fcl_add_header_only_boost_target(dll)
_fcl_add_header_only_boost_target(multi_index)
_fcl_add_header_only_boost_target(multiprecision)
find_dependency(OpenSSL 3.5 COMPONENTS SSL Crypto)
find_dependency(Ngtcp2)
find_dependency(glaze 7.5 CONFIG)
find_dependency(boost_stacktrace_basic CONFIG QUIET)

if(NOT TARGET GMP::gmp)
   find_path(GMP_INCLUDE_DIR NAMES gmp.h)
   find_library(GMP_LIBRARY gmp)
   if(NOT GMP_INCLUDE_DIR OR NOT GMP_LIBRARY)
      set(FCL_FOUND FALSE)
      set(FCL_NOT_FOUND_MESSAGE "FCL requires GMP::gmp for fcl_crypto, but gmp.h or libgmp was not found")
      return()
   endif()
   add_library(GMP::gmp SHARED IMPORTED)
   set_target_properties(
      GMP::gmp PROPERTIES
      IMPORTED_LOCATION "${GMP_LIBRARY}"
      INTERFACE_INCLUDE_DIRECTORIES "${GMP_INCLUDE_DIR}"
   )
endif()

find_package(Notcurses CONFIG QUIET)
if(NOT TARGET Notcurses::notcurses-core AND
   NOT TARGET notcurses::notcurses-core AND
   NOT TARGET notcurses-core AND
   NOT TARGET PkgConfig::NOTCURSES_CORE)
   find_package(PkgConfig QUIET)
   if(PkgConfig_FOUND)
      pkg_check_modules(NOTCURSES_CORE QUIET IMPORTED_TARGET notcurses-core)
   endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/FCLTargets.cmake")

check_required_components(FCL)
