@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/modules")
set(FCL_BUILT_WITH_ROCKSDB @FCL_HAS_ROCKSDB@)

set(
   _FCL_ALL_COMPONENTS
   core
   exceptions
   reflect
   schema
   variant
   raw
   json
   yaml
   config
   program_options
   env
   api
   api_transport
   log
   otlp
   crypto
   multiformats
   asio
   transport
   tcp
   stcp
   yamux
   app
   http
   websocket
   quic
   p2p
   plugin_signature_provider
   plugin_secret_provider
   plugin_p2p_node
   plugin_p2p_api_resolver
   plugin_p2p_diagnostics
   plugin_p2p_pubsub
   plugin_http_server
   plugins
   tui
)
set(_FCL_KNOWN_COMPONENTS ${_FCL_ALL_COMPONENTS} all)
set(_FCL_REQUESTED_COMPONENTS ${FCL_FIND_COMPONENTS})
set(_FCL_ALL_REQUESTED FALSE)

macro(_fcl_add_component component)
   if(NOT "${component}" IN_LIST _FCL_COMPONENTS)
      list(APPEND _FCL_COMPONENTS "${component}")

      if("${component}" STREQUAL "exceptions")
         _fcl_add_component(core)
      elseif("${component}" STREQUAL "reflect")
         _fcl_add_component(core)
      elseif("${component}" STREQUAL "schema")
         _fcl_add_component(reflect)
      elseif("${component}" STREQUAL "variant")
         _fcl_add_component(core)
         _fcl_add_component(reflect)
      elseif("${component}" STREQUAL "raw")
         _fcl_add_component(core)
         _fcl_add_component(exceptions)
         _fcl_add_component(reflect)
         _fcl_add_component(variant)
      elseif("${component}" STREQUAL "json")
         _fcl_add_component(core)
         _fcl_add_component(config)
         _fcl_add_component(schema)
         _fcl_add_component(variant)
      elseif("${component}" STREQUAL "yaml")
         _fcl_add_component(config)
         _fcl_add_component(schema)
         _fcl_add_component(variant)
      elseif("${component}" STREQUAL "config")
         _fcl_add_component(schema)
      elseif("${component}" STREQUAL "program_options")
         _fcl_add_component(config)
         _fcl_add_component(schema)
      elseif("${component}" STREQUAL "env")
         _fcl_add_component(config)
         _fcl_add_component(schema)
      elseif("${component}" STREQUAL "api")
         _fcl_add_component(exceptions)
         _fcl_add_component(raw)
      elseif("${component}" STREQUAL "api_transport")
         _fcl_add_component(api)
         _fcl_add_component(transport)
      elseif("${component}" STREQUAL "log")
         _fcl_add_component(core)
         _fcl_add_component(reflect)
         _fcl_add_component(variant)
      elseif("${component}" STREQUAL "otlp")
         _fcl_add_component(log)
         _fcl_add_component(http)
         _fcl_add_component(asio)
      elseif("${component}" STREQUAL "crypto")
         _fcl_add_component(core)
         _fcl_add_component(exceptions)
         _fcl_add_component(raw)
         _fcl_add_component(reflect)
         _fcl_add_component(variant)
      elseif("${component}" STREQUAL "multiformats")
         _fcl_add_component(crypto)
      elseif("${component}" STREQUAL "transport")
         _fcl_add_component(exceptions)
      elseif("${component}" STREQUAL "tcp")
         _fcl_add_component(transport)
      elseif("${component}" STREQUAL "stcp")
         _fcl_add_component(tcp)
         _fcl_add_component(crypto)
      elseif("${component}" STREQUAL "yamux")
         _fcl_add_component(transport)
      elseif("${component}" STREQUAL "app")
         _fcl_add_component(api)
         _fcl_add_component(asio)
         _fcl_add_component(config)
         _fcl_add_component(env)
         _fcl_add_component(program_options)
         _fcl_add_component(yaml)
      elseif("${component}" STREQUAL "http")
         _fcl_add_component(api)
         _fcl_add_component(asio)
         _fcl_add_component(json)
         _fcl_add_component(schema)
         _fcl_add_component(websocket)
      elseif("${component}" STREQUAL "websocket")
         _fcl_add_component(api)
         _fcl_add_component(asio)
      elseif("${component}" STREQUAL "quic")
         _fcl_add_component(api)
         _fcl_add_component(api_transport)
         _fcl_add_component(asio)
         _fcl_add_component(crypto)
         _fcl_add_component(transport)
      elseif("${component}" STREQUAL "p2p")
         _fcl_add_component(api)
         _fcl_add_component(api_transport)
         _fcl_add_component(asio)
         _fcl_add_component(multiformats)
         _fcl_add_component(quic)
         _fcl_add_component(tcp)
         _fcl_add_component(stcp)
         _fcl_add_component(yamux)
      elseif("${component}" STREQUAL "plugin_signature_provider")
         _fcl_add_component(app)
         _fcl_add_component(api)
         _fcl_add_component(config)
         _fcl_add_component(schema)
         _fcl_add_component(crypto)
      elseif("${component}" STREQUAL "plugin_secret_provider")
         _fcl_add_component(app)
         _fcl_add_component(api)
         _fcl_add_component(config)
         _fcl_add_component(schema)
         _fcl_add_component(crypto)
      elseif("${component}" STREQUAL "plugin_p2p_node")
         _fcl_add_component(app)
         _fcl_add_component(api)
         _fcl_add_component(api_transport)
         _fcl_add_component(schema)
         _fcl_add_component(p2p)
      elseif("${component}" STREQUAL "plugin_p2p_api_resolver")
         _fcl_add_component(plugin_p2p_node)
         _fcl_add_component(api_transport)
         _fcl_add_component(schema)
         _fcl_add_component(p2p)
      elseif("${component}" STREQUAL "plugin_p2p_diagnostics")
         _fcl_add_component(plugin_p2p_node)
         _fcl_add_component(schema)
         _fcl_add_component(p2p)
      elseif("${component}" STREQUAL "plugin_p2p_pubsub")
         _fcl_add_component(plugin_p2p_node)
         _fcl_add_component(raw)
         _fcl_add_component(schema)
         _fcl_add_component(p2p)
      elseif("${component}" STREQUAL "plugin_http_server")
         _fcl_add_component(app)
         _fcl_add_component(api)
         _fcl_add_component(config)
         _fcl_add_component(schema)
         _fcl_add_component(http)
      elseif("${component}" STREQUAL "plugins")
         _fcl_add_component(plugin_signature_provider)
         _fcl_add_component(plugin_secret_provider)
         _fcl_add_component(plugin_p2p_node)
         _fcl_add_component(plugin_p2p_api_resolver)
         _fcl_add_component(plugin_p2p_diagnostics)
         _fcl_add_component(plugin_p2p_pubsub)
         _fcl_add_component(plugin_http_server)
      endif()
   endif()
endmacro()

macro(_fcl_require_package package)
   find_dependency(${package} ${ARGN})
endmacro()

macro(_fcl_add_header_only_boost_target name)
   if(NOT TARGET Boost::${name})
      add_library(Boost::${name} INTERFACE IMPORTED)
      target_link_libraries(Boost::${name} INTERFACE Boost::headers)
   endif()
endmacro()

if(NOT _FCL_REQUESTED_COMPONENTS)
   _fcl_add_component(core)
else()
   foreach(_fcl_component IN LISTS _FCL_REQUESTED_COMPONENTS)
      if("${_fcl_component}" STREQUAL "all")
         set(_FCL_ALL_REQUESTED TRUE)
         foreach(_fcl_all_component IN LISTS _FCL_ALL_COMPONENTS)
            _fcl_add_component(${_fcl_all_component})
         endforeach()
      elseif("${_fcl_component}" IN_LIST _FCL_ALL_COMPONENTS)
         set(FCL_${_fcl_component}_FOUND TRUE)
         _fcl_add_component(${_fcl_component})
      else()
         set(FCL_${_fcl_component}_FOUND FALSE)
         set(FCL_NOT_FOUND_MESSAGE "Unknown FCL component: ${_fcl_component}")
      endif()
   endforeach()
endif()

set(_FCL_NEEDS_BOOST FALSE)
foreach(_fcl_component IN LISTS _FCL_COMPONENTS)
   if(NOT "${_fcl_component}" STREQUAL "tui")
      set(_FCL_NEEDS_BOOST TRUE)
   endif()
endforeach()

set(_FCL_BOOST_COMPONENTS)
if(_FCL_NEEDS_BOOST)
   list(APPEND _FCL_BOOST_COMPONENTS headers)
endif()
if("core" IN_LIST _FCL_COMPONENTS)
   list(APPEND _FCL_BOOST_COMPONENTS date_time)
endif()
if("http" IN_LIST _FCL_COMPONENTS)
   list(APPEND _FCL_BOOST_COMPONENTS url)
endif()
if("program_options" IN_LIST _FCL_COMPONENTS)
   list(APPEND _FCL_BOOST_COMPONENTS program_options)
endif()
if(_FCL_BOOST_COMPONENTS)
   list(REMOVE_DUPLICATES _FCL_BOOST_COMPONENTS)
   _fcl_require_package(Boost 1.90 CONFIG COMPONENTS ${_FCL_BOOST_COMPONENTS})
   _fcl_add_header_only_boost_target(asio)
   _fcl_add_header_only_boost_target(beast)
   _fcl_add_header_only_boost_target(crc)
   _fcl_add_header_only_boost_target(dll)
   _fcl_add_header_only_boost_target(multi_index)
   _fcl_add_header_only_boost_target(multiprecision)
endif()

if("log" IN_LIST _FCL_COMPONENTS)
   find_package(boost_stacktrace_basic CONFIG QUIET)
endif()

if("asio" IN_LIST _FCL_COMPONENTS OR "transport" IN_LIST _FCL_COMPONENTS)
   _fcl_require_package(Threads)
endif()

set(_FCL_OPENSSL_COMPONENTS)
if("crypto" IN_LIST _FCL_COMPONENTS)
   list(APPEND _FCL_OPENSSL_COMPONENTS Crypto)
endif()
if("http" IN_LIST _FCL_COMPONENTS OR "websocket" IN_LIST _FCL_COMPONENTS OR "stcp" IN_LIST _FCL_COMPONENTS)
   list(APPEND _FCL_OPENSSL_COMPONENTS SSL)
endif()
if("quic" IN_LIST _FCL_COMPONENTS OR "p2p" IN_LIST _FCL_COMPONENTS)
   list(APPEND _FCL_OPENSSL_COMPONENTS SSL Crypto)
endif()
if(_FCL_OPENSSL_COMPONENTS)
   list(REMOVE_DUPLICATES _FCL_OPENSSL_COMPONENTS)
   _fcl_require_package(OpenSSL 3 COMPONENTS ${_FCL_OPENSSL_COMPONENTS})
endif()

if("quic" IN_LIST _FCL_COMPONENTS OR "p2p" IN_LIST _FCL_COMPONENTS)
   _fcl_require_package(Ngtcp2)
endif()

if("p2p" IN_LIST _FCL_COMPONENTS AND FCL_BUILT_WITH_ROCKSDB)
   _fcl_require_package(RocksDB)
endif()

if("json" IN_LIST _FCL_COMPONENTS OR "yaml" IN_LIST _FCL_COMPONENTS)
   _fcl_require_package(glaze 7.5 CONFIG)
endif()

if("crypto" IN_LIST _FCL_COMPONENTS)
   find_path(GMP_INCLUDE_DIR gmp.h)
   find_library(GMP_LIBRARY NAMES gmp)
   if(NOT GMP_INCLUDE_DIR OR NOT GMP_LIBRARY)
      set(FCL_crypto_FOUND FALSE)
      set(FCL_NOT_FOUND_MESSAGE "FCL crypto component requires GMP")
   elseif(NOT TARGET GMP::gmp)
      add_library(GMP::gmp UNKNOWN IMPORTED)
      set_target_properties(GMP::gmp PROPERTIES IMPORTED_LOCATION "${GMP_LIBRARY}" INTERFACE_INCLUDE_DIRECTORIES "${GMP_INCLUDE_DIR}")
   endif()
endif()

if("tui" IN_LIST _FCL_COMPONENTS)
   find_package(Notcurses CONFIG QUIET)
   if(TARGET Notcurses::notcurses-core)
      add_library(PkgConfig::NOTCURSES_CORE INTERFACE IMPORTED)
      target_link_libraries(PkgConfig::NOTCURSES_CORE INTERFACE Notcurses::notcurses-core)
   elseif(NOT TARGET PkgConfig::NOTCURSES_CORE)
      find_package(PkgConfig QUIET)
      if(PkgConfig_FOUND)
         pkg_check_modules(NOTCURSES_CORE QUIET IMPORTED_TARGET notcurses-core)
      endif()
   endif()
   if(NOT TARGET PkgConfig::NOTCURSES_CORE)
      set(FCL_tui_FOUND FALSE)
      set(FCL_NOT_FOUND_MESSAGE "FCL tui component requires notcurses-core")
   endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/FCLTargets.cmake")

foreach(_fcl_component IN LISTS _FCL_REQUESTED_COMPONENTS)
   if("${_fcl_component}" STREQUAL "all")
      if(NOT TARGET FCL::fcl)
         set(FCL_all_FOUND FALSE)
      endif()
   elseif("${_fcl_component}" IN_LIST _FCL_ALL_COMPONENTS)
      set(_fcl_expected_target "FCL::fcl_${_fcl_component}")
      if(NOT TARGET ${_fcl_expected_target})
         set(FCL_${_fcl_component}_FOUND FALSE)
      endif()
   endif()
endforeach()

if(_FCL_ALL_REQUESTED)
   set(FCL_all_FOUND TRUE)

   if(NOT TARGET FCL::fcl)
      set(FCL_all_FOUND FALSE)
      if(NOT FCL_NOT_FOUND_MESSAGE)
         set(FCL_NOT_FOUND_MESSAGE "FCL all component requires FCL::fcl target")
      endif()
   endif()

   foreach(_fcl_all_component IN LISTS _FCL_ALL_COMPONENTS)
      set(_fcl_component_found_var "FCL_${_fcl_all_component}_FOUND")
      if(DEFINED ${_fcl_component_found_var} AND NOT ${_fcl_component_found_var})
         set(FCL_all_FOUND FALSE)
         if(NOT FCL_NOT_FOUND_MESSAGE)
            set(FCL_NOT_FOUND_MESSAGE "FCL all component requires ${_fcl_all_component} component")
         endif()
      endif()

      if(NOT TARGET FCL::fcl_${_fcl_all_component})
         set(FCL_all_FOUND FALSE)
         if(NOT FCL_NOT_FOUND_MESSAGE)
            set(FCL_NOT_FOUND_MESSAGE "FCL all component requires FCL::fcl_${_fcl_all_component} target")
         endif()
      endif()
   endforeach()
endif()

check_required_components(FCL)
