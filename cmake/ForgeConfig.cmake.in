@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/modules")
set(Forge_BUILT_WITH_ROCKSDB @FORGE_HAS_ROCKSDB@)

set(
   _FORGE_ALL_COMPONENTS
   core
   exceptions
   reflect
   schema
   variant
   raw
   objectdb
   json
   yaml
   xml
   config
   program_options
   env
   api
   transport_api
   log
   otlp
   rocksdb
   crypto
   multiformats
   asio
   transport
   tcp
   stcp
   yamux
   app
   http
   http_api
   websocket
   quic
   p2p
   plugins_crypto_signer
   plugins_crypto_secrets
   plugins_p2p_node
   plugins_p2p_resolver
   plugins_p2p_diagnostics
   plugins_p2p_pubsub
   plugins_http_server
   plugins_log_otlp
   plugins_db_rocksdb
   plugins
   tui
)
set(_FORGE_KNOWN_COMPONENTS ${_FORGE_ALL_COMPONENTS} all)
set(_FORGE_REQUESTED_COMPONENTS ${Forge_FIND_COMPONENTS})
set(_FORGE_ALL_REQUESTED FALSE)

macro(_forge_add_component component)
   if(NOT "${component}" IN_LIST _FORGE_COMPONENTS)
      list(APPEND _FORGE_COMPONENTS "${component}")

      if("${component}" STREQUAL "exceptions")
         _forge_add_component(core)
      elseif("${component}" STREQUAL "reflect")
         _forge_add_component(core)
      elseif("${component}" STREQUAL "schema")
         _forge_add_component(reflect)
      elseif("${component}" STREQUAL "variant")
         _forge_add_component(core)
         _forge_add_component(reflect)
      elseif("${component}" STREQUAL "raw")
         _forge_add_component(core)
         _forge_add_component(exceptions)
         _forge_add_component(reflect)
         _forge_add_component(variant)
      elseif("${component}" STREQUAL "objectdb")
         _forge_add_component(exceptions)
      elseif("${component}" STREQUAL "json")
         _forge_add_component(core)
         _forge_add_component(config)
         _forge_add_component(schema)
         _forge_add_component(variant)
      elseif("${component}" STREQUAL "yaml")
         _forge_add_component(config)
         _forge_add_component(schema)
         _forge_add_component(variant)
      elseif("${component}" STREQUAL "xml")
         _forge_add_component(config)
         _forge_add_component(core)
         _forge_add_component(reflect)
         _forge_add_component(schema)
      elseif("${component}" STREQUAL "config")
         _forge_add_component(schema)
      elseif("${component}" STREQUAL "program_options")
         _forge_add_component(config)
         _forge_add_component(schema)
      elseif("${component}" STREQUAL "env")
         _forge_add_component(config)
         _forge_add_component(schema)
      elseif("${component}" STREQUAL "api")
         _forge_add_component(exceptions)
         _forge_add_component(raw)
      elseif("${component}" STREQUAL "transport_api")
         _forge_add_component(api)
         _forge_add_component(transport)
      elseif("${component}" STREQUAL "log")
         _forge_add_component(core)
         _forge_add_component(reflect)
         _forge_add_component(variant)
      elseif("${component}" STREQUAL "otlp")
         _forge_add_component(log)
         _forge_add_component(http)
         _forge_add_component(asio)
      elseif("${component}" STREQUAL "rocksdb")
         if(NOT Forge_BUILT_WITH_ROCKSDB)
            set(Forge_rocksdb_FOUND FALSE)
            if(NOT Forge_NOT_FOUND_MESSAGE)
               set(Forge_NOT_FOUND_MESSAGE "Forge rocksdb component requires Forge built with RocksDB")
            endif()
         else()
            _forge_add_component(exceptions)
            _forge_add_component(schema)
         endif()
      elseif("${component}" STREQUAL "crypto")
         _forge_add_component(core)
         _forge_add_component(exceptions)
         _forge_add_component(raw)
         _forge_add_component(reflect)
         _forge_add_component(variant)
      elseif("${component}" STREQUAL "multiformats")
         _forge_add_component(crypto)
      elseif("${component}" STREQUAL "transport")
         _forge_add_component(exceptions)
      elseif("${component}" STREQUAL "tcp")
         _forge_add_component(transport)
      elseif("${component}" STREQUAL "stcp")
         _forge_add_component(tcp)
         _forge_add_component(crypto)
      elseif("${component}" STREQUAL "yamux")
         _forge_add_component(transport)
      elseif("${component}" STREQUAL "app")
         _forge_add_component(api)
         _forge_add_component(asio)
         _forge_add_component(config)
         _forge_add_component(env)
         _forge_add_component(program_options)
         _forge_add_component(yaml)
      elseif("${component}" STREQUAL "http")
         _forge_add_component(api)
         _forge_add_component(asio)
         _forge_add_component(json)
         _forge_add_component(schema)
         _forge_add_component(websocket)
      elseif("${component}" STREQUAL "http_api")
         _forge_add_component(http)
         _forge_add_component(api)
         _forge_add_component(json)
         _forge_add_component(xml)
         _forge_add_component(raw)
         _forge_add_component(reflect)
         _forge_add_component(schema)
      elseif("${component}" STREQUAL "websocket")
         _forge_add_component(api)
         _forge_add_component(asio)
      elseif("${component}" STREQUAL "quic")
         _forge_add_component(api)
         _forge_add_component(transport_api)
         _forge_add_component(asio)
         _forge_add_component(crypto)
         _forge_add_component(transport)
      elseif("${component}" STREQUAL "p2p")
         _forge_add_component(api)
         _forge_add_component(transport_api)
         _forge_add_component(asio)
         _forge_add_component(multiformats)
         _forge_add_component(quic)
         _forge_add_component(tcp)
         _forge_add_component(stcp)
         _forge_add_component(yamux)
         if(Forge_BUILT_WITH_ROCKSDB)
            _forge_add_component(rocksdb)
         endif()
      elseif("${component}" STREQUAL "plugins_crypto_signer")
         _forge_add_component(app)
         _forge_add_component(api)
         _forge_add_component(config)
         _forge_add_component(schema)
         _forge_add_component(crypto)
      elseif("${component}" STREQUAL "plugins_crypto_secrets")
         _forge_add_component(app)
         _forge_add_component(api)
         _forge_add_component(config)
         _forge_add_component(schema)
         _forge_add_component(crypto)
      elseif("${component}" STREQUAL "plugins_p2p_node")
         _forge_add_component(app)
         _forge_add_component(api)
         _forge_add_component(transport_api)
         _forge_add_component(schema)
         _forge_add_component(p2p)
      elseif("${component}" STREQUAL "plugins_p2p_resolver")
         _forge_add_component(plugins_p2p_node)
         _forge_add_component(transport_api)
         _forge_add_component(schema)
         _forge_add_component(p2p)
      elseif("${component}" STREQUAL "plugins_p2p_diagnostics")
         _forge_add_component(plugins_p2p_node)
         _forge_add_component(schema)
         _forge_add_component(p2p)
      elseif("${component}" STREQUAL "plugins_p2p_pubsub")
         _forge_add_component(plugins_p2p_node)
         _forge_add_component(raw)
         _forge_add_component(schema)
         _forge_add_component(p2p)
      elseif("${component}" STREQUAL "plugins_http_server")
         _forge_add_component(app)
         _forge_add_component(api)
         _forge_add_component(config)
         _forge_add_component(schema)
         _forge_add_component(http)
         _forge_add_component(http_api)
      elseif("${component}" STREQUAL "plugins_log_otlp")
         _forge_add_component(app)
         _forge_add_component(api)
         _forge_add_component(config)
         _forge_add_component(schema)
         _forge_add_component(log)
         _forge_add_component(otlp)
         _forge_add_component(http)
      elseif("${component}" STREQUAL "plugins_db_rocksdb")
         if(NOT Forge_BUILT_WITH_ROCKSDB)
            set(Forge_plugins_db_rocksdb_FOUND FALSE)
            if(NOT Forge_NOT_FOUND_MESSAGE)
               set(Forge_NOT_FOUND_MESSAGE "Forge plugins_db_rocksdb component requires Forge built with RocksDB")
            endif()
         else()
            _forge_add_component(app)
            _forge_add_component(api)
            _forge_add_component(asio)
            _forge_add_component(config)
            _forge_add_component(schema)
            _forge_add_component(rocksdb)
         endif()
      elseif("${component}" STREQUAL "plugins")
         _forge_add_component(plugins_crypto_signer)
         _forge_add_component(plugins_crypto_secrets)
         _forge_add_component(plugins_p2p_node)
         _forge_add_component(plugins_p2p_resolver)
         _forge_add_component(plugins_p2p_diagnostics)
         _forge_add_component(plugins_p2p_pubsub)
         _forge_add_component(plugins_http_server)
         _forge_add_component(plugins_log_otlp)
         if(Forge_BUILT_WITH_ROCKSDB)
            _forge_add_component(plugins_db_rocksdb)
         endif()
      endif()
   endif()
endmacro()

macro(_forge_require_package package)
   find_dependency(${package} ${ARGN})
endmacro()

macro(_forge_add_header_only_boost_target name)
   if(NOT TARGET Boost::${name})
      add_library(Boost::${name} INTERFACE IMPORTED)
      target_link_libraries(Boost::${name} INTERFACE Boost::headers)
   endif()
endmacro()

if(NOT _FORGE_REQUESTED_COMPONENTS)
   _forge_add_component(core)
else()
   foreach(_forge_component IN LISTS _FORGE_REQUESTED_COMPONENTS)
      if("${_forge_component}" STREQUAL "all")
         set(_FORGE_ALL_REQUESTED TRUE)
         foreach(_forge_all_component IN LISTS _FORGE_ALL_COMPONENTS)
            _forge_add_component(${_forge_all_component})
         endforeach()
      elseif("${_forge_component}" IN_LIST _FORGE_ALL_COMPONENTS)
         set(Forge_${_forge_component}_FOUND TRUE)
         _forge_add_component(${_forge_component})
      else()
         set(Forge_${_forge_component}_FOUND FALSE)
         set(Forge_NOT_FOUND_MESSAGE "Unknown FORGE component: ${_forge_component}")
      endif()
   endforeach()
endif()

set(_FORGE_NEEDS_BOOST FALSE)
foreach(_forge_component IN LISTS _FORGE_COMPONENTS)
   if(NOT "${_forge_component}" STREQUAL "tui")
      set(_FORGE_NEEDS_BOOST TRUE)
   endif()
endforeach()

set(_FORGE_BOOST_COMPONENTS)
if(_FORGE_NEEDS_BOOST)
   list(APPEND _FORGE_BOOST_COMPONENTS headers)
endif()
if("core" IN_LIST _FORGE_COMPONENTS)
   list(APPEND _FORGE_BOOST_COMPONENTS date_time)
endif()
if("http" IN_LIST _FORGE_COMPONENTS)
   list(APPEND _FORGE_BOOST_COMPONENTS url)
endif()
if("program_options" IN_LIST _FORGE_COMPONENTS)
   list(APPEND _FORGE_BOOST_COMPONENTS program_options)
endif()
if(_FORGE_BOOST_COMPONENTS)
   list(REMOVE_DUPLICATES _FORGE_BOOST_COMPONENTS)
   _forge_require_package(Boost 1.90 CONFIG COMPONENTS ${_FORGE_BOOST_COMPONENTS})
   _forge_add_header_only_boost_target(asio)
   _forge_add_header_only_boost_target(beast)
   _forge_add_header_only_boost_target(crc)
   _forge_add_header_only_boost_target(dll)
   _forge_add_header_only_boost_target(multi_index)
   _forge_add_header_only_boost_target(multiprecision)
endif()

if("log" IN_LIST _FORGE_COMPONENTS)
   find_package(boost_stacktrace_basic CONFIG QUIET)
endif()

if("asio" IN_LIST _FORGE_COMPONENTS OR "transport" IN_LIST _FORGE_COMPONENTS)
   _forge_require_package(Threads)
endif()

set(_FORGE_OPENSSL_COMPONENTS)
if("crypto" IN_LIST _FORGE_COMPONENTS)
   list(APPEND _FORGE_OPENSSL_COMPONENTS Crypto)
endif()
if("http" IN_LIST _FORGE_COMPONENTS OR "websocket" IN_LIST _FORGE_COMPONENTS OR "stcp" IN_LIST _FORGE_COMPONENTS)
   list(APPEND _FORGE_OPENSSL_COMPONENTS SSL)
endif()
if("quic" IN_LIST _FORGE_COMPONENTS OR "p2p" IN_LIST _FORGE_COMPONENTS)
   list(APPEND _FORGE_OPENSSL_COMPONENTS SSL Crypto)
endif()
if(_FORGE_OPENSSL_COMPONENTS)
   list(REMOVE_DUPLICATES _FORGE_OPENSSL_COMPONENTS)
   _forge_require_package(OpenSSL 3 COMPONENTS ${_FORGE_OPENSSL_COMPONENTS})
endif()

if("quic" IN_LIST _FORGE_COMPONENTS OR "p2p" IN_LIST _FORGE_COMPONENTS)
   _forge_require_package(Ngtcp2)
endif()

if(Forge_BUILT_WITH_ROCKSDB)
   if("rocksdb" IN_LIST _FORGE_COMPONENTS OR "p2p" IN_LIST _FORGE_COMPONENTS OR "plugins_db_rocksdb" IN_LIST _FORGE_COMPONENTS)
      _forge_require_package(RocksDB)
   endif()
endif()

if("json" IN_LIST _FORGE_COMPONENTS OR "yaml" IN_LIST _FORGE_COMPONENTS)
   _forge_require_package(glaze 7.5 CONFIG)
endif()

if("crypto" IN_LIST _FORGE_COMPONENTS)
   find_path(GMP_INCLUDE_DIR gmp.h)
   find_library(GMP_LIBRARY NAMES gmp)
   if(NOT GMP_INCLUDE_DIR OR NOT GMP_LIBRARY)
      set(Forge_crypto_FOUND FALSE)
      set(Forge_NOT_FOUND_MESSAGE "Forge crypto component requires GMP")
   elseif(NOT TARGET GMP::gmp)
      add_library(GMP::gmp UNKNOWN IMPORTED)
      set_target_properties(GMP::gmp PROPERTIES IMPORTED_LOCATION "${GMP_LIBRARY}" INTERFACE_INCLUDE_DIRECTORIES "${GMP_INCLUDE_DIR}")
   endif()
endif()

if("tui" IN_LIST _FORGE_COMPONENTS)
   find_package(Notcurses CONFIG QUIET)
   if(TARGET Notcurses::notcurses-core)
      add_library(PkgConfig::NOTCURSES_CORE INTERFACE IMPORTED)
      target_link_libraries(PkgConfig::NOTCURSES_CORE INTERFACE Notcurses::notcurses-core)
   elseif(NOT TARGET PkgConfig::NOTCURSES_CORE)
      find_package(PkgConfig QUIET)
      if(PkgConfig_FOUND)
         pkg_check_modules(NOTCURSES_CORE QUIET IMPORTED_TARGET notcurses-core)
      endif()
   endif()
   if(NOT TARGET PkgConfig::NOTCURSES_CORE)
      set(Forge_tui_FOUND FALSE)
      set(Forge_NOT_FOUND_MESSAGE "Forge tui component requires notcurses-core")
   endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/ForgeTargets.cmake")

foreach(_forge_component IN LISTS _FORGE_REQUESTED_COMPONENTS)
   if("${_forge_component}" STREQUAL "all")
      if(NOT TARGET Forge::forge)
         set(Forge_all_FOUND FALSE)
      endif()
   elseif("${_forge_component}" IN_LIST _FORGE_ALL_COMPONENTS)
      set(_forge_expected_target "Forge::forge_${_forge_component}")
      if(NOT TARGET ${_forge_expected_target})
         set(Forge_${_forge_component}_FOUND FALSE)
      endif()
   endif()
endforeach()

if(_FORGE_ALL_REQUESTED)
   set(Forge_all_FOUND TRUE)

   if(NOT TARGET Forge::forge)
      set(Forge_all_FOUND FALSE)
      if(NOT Forge_NOT_FOUND_MESSAGE)
         set(Forge_NOT_FOUND_MESSAGE "Forge all component requires Forge::forge target")
      endif()
   endif()

   foreach(_forge_all_component IN LISTS _FORGE_ALL_COMPONENTS)
      set(_forge_component_found_var "Forge_${_forge_all_component}_FOUND")
      if(DEFINED ${_forge_component_found_var} AND NOT ${_forge_component_found_var})
         set(Forge_all_FOUND FALSE)
         if(NOT Forge_NOT_FOUND_MESSAGE)
            set(Forge_NOT_FOUND_MESSAGE "Forge all component requires ${_forge_all_component} component")
         endif()
      endif()

      if(NOT TARGET Forge::forge_${_forge_all_component})
         set(Forge_all_FOUND FALSE)
         if(NOT Forge_NOT_FOUND_MESSAGE)
            set(Forge_NOT_FOUND_MESSAGE "Forge all component requires Forge::forge_${_forge_all_component} target")
         endif()
      endif()
   endforeach()
endif()

check_required_components(Forge)
